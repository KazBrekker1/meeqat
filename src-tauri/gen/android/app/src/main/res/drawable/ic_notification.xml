<?xml version="1.0" encoding="utf-8"?>
<!-- Meeqat mark (orbit ring + now-dot + crescent moon) as a monochrome
     status-bar / notification icon. The system tints it, so keep it
     white-on-transparent. The ring is a filled annulus (even-odd) rather than a
     stroke so it stays crisp and legible at small status-bar sizes.
     NOTE: this app-module drawable shadows the plugin's drawable of the same
     name during resource merging, so it is the one that actually renders. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24"
    android:tint="#FFFFFF">
    <!-- orbit ring -->
    <path
        android:fillColor="#FFFFFF"
        android:fillType="evenOdd"
        android:pathData="M2,12 a10,10 0 1,0 20,0 a10,10 0 1,0 -20,0 Z M3.6,12 a8.4,8.4 0 1,0 16.8,0 a8.4,8.4 0 1,0 -16.8,0 Z" />
    <!-- now-dot on the ring (lower-left) -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M2.3,17.7 a1.5,1.5 0 1,0 3,0 a1.5,1.5 0 1,0 -3,0" />
    <!-- crescent moon at the centre -->
    <group
        android:pivotX="12"
        android:pivotY="12"
        android:scaleX="0.5"
        android:scaleY="0.5">
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M12,3 a6,6 0 0 0 9,9 9,9 0 1 1 -9,-9 Z" />
    </group>
</vector>
