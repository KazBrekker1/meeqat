<?xml version="1.0" encoding="utf-8"?>
<!-- Aurora glass: celestial navy gradient, lighter toward the top-right corner. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:type="linear"
        android:angle="225"
        android:startColor="#1f2a63"
        android:centerColor="#141c40"
        android:endColor="#0a0e22" />
    <corners android:radius="20dp" />
</shape>
