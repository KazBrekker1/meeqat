<?xml version="1.0" encoding="utf-8"?>
<!-- Current-prayer row: a faint amber wash with a slim left accent bar — replaces
     the heavy full-pill highlight in the vertical times list. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#14FCD34D" />
            <corners android:radius="12dp" />
        </shape>
    </item>
    <item
        android:width="4dp"
        android:start="2dp"
        android:gravity="start">
        <shape android:shape="rectangle">
            <solid android:color="#FFFCD34D" />
            <corners android:radius="2dp" />
        </shape>
    </item>
</layer-list>
